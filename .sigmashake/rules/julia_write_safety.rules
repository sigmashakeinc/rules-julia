# julia_write_safety.rules
# Technology: julia | Capability: write

rule julia-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "ccall("
  MESSAGE "Blocked an unsafe pattern in julia. Use the recommended best practices for 2025/2026."
}

rule julia-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "Nullable"
  MESSAGE "You are using an outdated API for julia. Please upgrade to the newer API."
}
